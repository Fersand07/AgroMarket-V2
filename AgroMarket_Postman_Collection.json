{
  "info": {
    "name": "AgroMarket API",
    "description": "Postman collection for the AgroMarket API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        { "name": "Login", "request": { "method": "POST", "url": "{{baseUrl}}/auth/login", "body": { "mode": "raw", "raw": "{\n  \"username\": \"string\",\n  \"password\": \"string\"\n}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Register", "request": { "method": "POST", "url": "{{baseUrl}}/auth/register", "body": { "mode": "raw", "raw": "{\n  \"username\": \"string\",\n  \"email\": \"string\",\n  \"address\": \"string\",\n  \"phone\": \"string\",\n  \"password\": \"string\"\n}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Refresh Token", "request": { "method": "GET", "url": "{{baseUrl}}/auth/refresh" } },
        { "name": "Logout", "request": { "method": "GET", "url": "{{baseUrl}}/auth/logout" } }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "Get All Products", "request": { "method": "GET", "url": "{{baseUrl}}/products/all" } },
        { "name": "Get Product By ID", "request": { "method": "GET", "url": "{{baseUrl}}/products/1" } },
        { "name": "Get Nearby Products", "request": { "method": "GET", "url": "{{baseUrl}}/products/nearby" } },
        { "name": "Get Products By Category", "request": { "method": "GET", "url": "{{baseUrl}}/products/category/1" } },
        { "name": "Get User's Own Products", "request": { "method": "GET", "url": "{{baseUrl}}/products/user/ownProducts" } },
        { "name": "Create Product", "request": { "method": "POST", "url": "{{baseUrl}}/products/create" } },
        { "name": "Update Product", "request": { "method": "PATCH", "url": "{{baseUrl}}/products/update/1" } },
        { "name": "Delete Product", "request": { "method": "DELETE", "url": "{{baseUrl}}/products/delete/1" } },
        { "name": "Buy Product", "request": { "method": "POST", "url": "{{baseUrl}}/products/buy/1" } }
      ]
    },
    {
      "name": "Profile",
      "item": [
        { "name": "Get Profile Info", "request": { "method": "GET", "url": "{{baseUrl}}/profile/info" } },
        { "name": "Update Profile", "request": { "method": "PATCH", "url": "{{baseUrl}}/profile/update" } },
        { "name": "Change Password", "request": { "method": "PUT", "url": "{{baseUrl}}/profile/change-password" } },
        { "name": "Change Image", "request": { "method": "PUT", "url": "{{baseUrl}}/profile/change-image" } },
        { "name": "Get Nearby Sellers", "request": { "method": "GET", "url": "{{baseUrl}}/profile/nearby-sellers" } }
      ]
    },
    {
      "name": "Cart",
      "item": [
        { "name": "Get Cart", "request": { "method": "GET", "url": "{{baseUrl}}/cart/" } },
        { "name": "Add to Cart", "request": { "method": "POST", "url": "{{baseUrl}}/cart/add" } },
        { "name": "Remove from Cart", "request": { "method": "DELETE", "url": "{{baseUrl}}/cart/remove" } },
        { "name": "Update Cart Items", "request": { "method": "PATCH", "url": "{{baseUrl}}/cart/update" } },
        { "name": "Clear Cart", "request": { "method": "POST", "url": "{{baseUrl}}/cart/clear" } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        { "name": "Get All Orders", "request": { "method": "GET", "url": "{{baseUrl}}/orders/" } },
        { "name": "Get Order by ID", "request": { "method": "GET", "url": "{{baseUrl}}/orders/1" } },
        { "name": "Create Order", "request": { "method": "POST", "url": "{{baseUrl}}/orders/" } },
        { "name": "Update Order", "request": { "method": "PUT", "url": "{{baseUrl}}/orders/1" } },
        { "name": "Update Order Status", "request": { "method": "PATCH", "url": "{{baseUrl}}/orders/status/1" } },
        { "name": "Delete Order", "request": { "method": "DELETE", "url": "{{baseUrl}}/orders/1" } }
      ]
    },
    {
      "name": "Data Methods",
      "item": [
        { "name": "Get Categories", "request": { "method": "GET", "url": "{{baseUrl}}/data/categories" } },
        { "name": "Get Measure Units", "request": { "method": "GET", "url": "{{baseUrl}}/data/measureUnits" } }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        { "name": "Get Transactions", "request": { "method": "GET", "url": "{{baseUrl}}/transactions/get" } },
        { "name": "Add Transaction", "request": { "method": "POST", "url": "{{baseUrl}}/transactions/add" } }
      ]
    },
    {
      "name": "Credits",
      "item": [
        { "name": "Get Credits", "request": { "method": "GET", "url": "{{baseUrl}}/credits/get" } },
        { "name": "Add Credits", "request": { "method": "POST", "url": "{{baseUrl}}/credits/add" } },
        { "name": "Subtract Credits", "request": { "method": "POST", "url": "{{baseUrl}}/credits/substract" } }
      ]
    },
    {
      "name": "Upload Sample Data",
      "item": [
        { "name": "Sample Categories", "request": { "method": "POST", "url": "{{baseUrl}}/upload/sample1" } },
        { "name": "Sample Measure Units", "request": { "method": "POST", "url": "{{baseUrl}}/upload/sample2" } },
        { "name": "Sample Products", "request": { "method": "POST", "url": "{{baseUrl}}/upload/sample3" } }
      ]
    }
  ]
}
